# clang-tidy configuration for recovery-qt
# Maintainer: Sinan Islekdemir <sinan@islekdemir.com>
#
# Focus on real defects (bugprone, static analyzer, performance).
# Style churn and checks that are hopeless on the legacy testdisk C core
# are disabled deliberately.
---
Checks: >
  bugprone-*,
  clang-analyzer-*,
  performance-*,
  portability-*,
  misc-redundant-expression,
  readability-misleading-indentation,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-branch-clone,
  -bugprone-assignment-in-if-condition,
  -bugprone-implicit-widening-of-multiplication-result,
  -bugprone-multi-level-implicit-pointer-conversion,
  -bugprone-reserved-identifier,
  -bugprone-signed-char-misuse,
  -bugprone-macro-parentheses,
  -bugprone-casting-through-void,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling,
  -clang-analyzer-security.insecureAPI.strcpy,
  -clang-diagnostic-unknown-attributes,
  -performance-no-int-to-ptr
WarningsAsErrors: ''
HeaderFilterRegex: 'src/(core|disk|fs|formats|include|common|ui|wrappers)/'
FormatStyle: file
